&lt;script>
(function() {
let currentGalleryArray = [];
let currentIndex = 0;
function openGalleryModal(link) {
const container = link.closest('.gallery-container');
if (!container) return;
const links = container.querySelectorAll('.gallery-lightbox');
currentGalleryArray = Array.from(links).map(l => ({
src: l.dataset.full,
caption: l.dataset.caption || ''
}));
currentIndex = parseInt(link.dataset.index, 10) || 0;
updateModalContent();
document.getElementById('gallery-modal').style.display = 'flex';
}
function closeGalleryModal() {
document.getElementById('gallery-modal').style.display = 'none';
}
function galleryModalNavigate(delta) {
if (currentGalleryArray.length === 0) return;
currentIndex = (currentIndex + delta + currentGalleryArray.length) % currentGalleryArray.length;
updateModalContent();
}
function updateModalContent() {
const item = currentGalleryArray[currentIndex];
document.getElementById('gallery-modal-img').src = item.src;
document.getElementById('gallery-modal-caption').textContent = item.caption;
}
document.addEventListener('click', function(e) {
const link = e.target.closest('.gallery-lightbox');
if (link) {
e.preventDefault();
openGalleryModal(link);
}
});
document.getElementById('gallery-modal').addEventListener('click', function(e) {
if (e.target === this) closeGalleryModal();
});
window.galleryModalNavigate = galleryModalNavigate;
window.closeGalleryModal = closeGalleryModal;
})();
