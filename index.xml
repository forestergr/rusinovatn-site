          &lt;th style=&#34;text-align: center&#34;&gt;Предмет&lt;/th&gt;
          &lt;th style=&#34;text-align: center&#34;&gt;Классы&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;&lt;div style=&#34;text-align: justify;&#34;&gt;
  математика для интересующихся
&lt;/div&gt;&lt;/td&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;$5^а, 5^в, 5^м$&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;&lt;div style=&#34;text-align: justify;&#34;&gt;
  математика для увлеченных
&lt;/div&gt;&lt;/td&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;$6^а, 6^б, 6^в$&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;&lt;div style=&#34;text-align: justify;&#34;&gt;
  алгебра, геометрия, вероятность и статистика
&lt;/div&gt;&lt;/td&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;$7^б, 8^б, 8^в$&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;&amp;ndash;&amp;gt;&lt;/td&gt;
